# modules fix

CONFIG_MODULES=y
CONFIG_MODULE_FORCE_LOAD=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y
# CONFIG_MODULE_SIG_FORCE is not set

# Force the MediaTek out-of-tree framework to compile inline
CONFIG_DRV_BUILD_IN=y

# Switch all connectivity sub-components to built-in (=y)
CONFIG_MTK_COMBO_COMM=y
CONFIG_MTK_COMBO_BT=y
CONFIG_MTK_COMBO_WIFI=y
CONFIG_WLAN=y
CONFIG_MTK_COMBO_GPS=y
CONFIG_MTK_GPS_SUPPORT=y
CONFIG_MTK_FMRADIO=y
